BoxLayout:
    orientation: 'vertical'

    BoxLayout:
        orientation: 'horizontal'
        TextInput:
            id: input_number
            text: '7'
            font_size: 20
            multiline: False
        Button:
            text: 'Square'
            # the following line specifies the function in the app class to call when the button is pressed
            on_press: app.handle_calculate(input_number.text)
#            on_press: app.handle_calculate(int(input_number.text))
        Label:
            id: output_label
            font_size: 20
            color: (1,0.21,0.76, 1)

    Label:
        text: 'Enter a number and press "Square" '
